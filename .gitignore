# ────────────────────────────────────────────────────────────────────────────
# downwash .gitignore
# ────────────────────────────────────────────────────────────────────────────

# Compiled binaries
downwash
downwash.exe
dist/

# Go toolchain
*.test
*.out
*.exe~
vendor/
coverage.html
coverage.txt

# goreleaser
dist/

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Linux
*~
\#*\#

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.project
.classpath
.settings/

# Environment / secrets
.env
.env.*
*.pem
*.key

# Output artefacts (keep samples/)
*.gpx
*.pdf
!samples/*.gpx
!samples/*.pdf
*.mp4
!samples/*.mp4

# Don't ignore PNG charts in samples/
*.png
!samples/*.png
